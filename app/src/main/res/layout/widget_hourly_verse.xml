<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_hourly_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg_light_green"
    android:padding="12dp">

    <!-- Header info -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/widget_hourly_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ঘণ্টার বিশেষ আয়াত (Hourly)"
            android:textColor="#0F5E36"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_alignParentStart="true" />

        <TextView
            android:id="@+id/widget_hourly_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="পড়ুন ও শুনুন"
            android:textColor="#388E3C"
            android:textSize="10sp"
            android:textStyle="bold"
            android:layout_alignParentEnd="true" />
    </RelativeLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#B5E3C4"
        android:layout_marginTop="5dp"
        android:layout_marginBottom="6dp" />

    <!-- Container for scrollable height weight to hold texts nicely -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <!-- Arabic text with uniform autosizing -->
        <TextView
            android:id="@+id/widget_hourly_arabic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="مَلِكِ يَوْمِ الدِّينِ"
            android:textColor="#0B4B2A"
            android:textSize="32sp"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="12sp"
            android:autoSizeMaxTextSize="44sp"
            android:autoSizeStepGranularity="1sp"
            android:maxLines="3"
            android:gravity="end"
            android:paddingBottom="4dp"
            android:lineSpacingMultiplier="1.25" />

        <!-- Bangla translation with uniform autosizing -->
        <TextView
            android:id="@+id/widget_hourly_bangla"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="যিনি বিচার দিনের মালিক।"
            android:textColor="#2E7D32"
            android:textSize="18sp"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="10sp"
            android:autoSizeMaxTextSize="22sp"
            android:autoSizeStepGranularity="1sp"
            android:maxLines="3"
            android:paddingTop="2dp"
            android:lineSpacingMultiplier="1.15" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#C2E6CE"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp" />

    <!-- Footer Row (Copy Button and citation) -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_hourly_citation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="নিয়মিত আয়াত পাঠ করুন"
            android:textColor="#2E7D32"
            android:textSize="10sp"
            android:textStyle="bold"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true" />

        <ImageButton
            android:id="@+id/btn_widget_copy"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/widget_round_btn_ripple"
            android:src="@android:drawable/ic_menu_share"
            android:tint="#0F5E36"
            android:padding="6dp"
            android:scaleType="fitCenter"
            android:contentDescription="কপি করুন" />
    </RelativeLayout>

</LinearLayout>
