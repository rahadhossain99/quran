<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Premium Minty Background Gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#F4FDF7"
                android:endColor="#E6F9EE"
                android:angle="135" />
            <corners android:radius="24dp" />
            <stroke
                android:width="1.5dp"
                android:color="#A7E1BB" />
        </shape>
    </item>

    <!-- Inner beautiful decorative frame -->
    <item android:left="4dp" android:right="4dp" android:top="4dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <stroke
                android:width="0.8dp"
                android:color="#402E7D32" /> <!-- Soft Green Alpha Border -->
        </shape>
    </item>
</layer-list>
