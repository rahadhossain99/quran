<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base Layer: Imperial deep Emerald Green Gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#0A3F25"
                android:centerColor="#052917"
                android:endColor="#031E10"
                android:angle="135" />
            <corners android:radius="24dp" />
            <stroke
                android:width="2dp"
                android:color="#21643C" />
        </shape>
    </item>

    <!-- Layer 2: Subtle textured diagonal gold ray overlay simulation -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#0DFFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="45" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- Layer 3: Main Outer Golden ornamental border -->
    <item android:left="5dp" android:right="5dp" android:top="5dp" android:bottom="5dp">
        <shape android:shape="rectangle">
            <corners android:radius="19dp" />
            <stroke
                android:width="1.2dp"
                android:color="#D4AF37" /> <!-- Premium Gold Cover -->
        </shape>
    </item>

    <!-- Layer 4: Fine Inner concentric green-and-gold frame for texture depth -->
    <item android:left="8dp" android:right="8dp" android:top="8dp" android:bottom="8dp">
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <stroke
                android:width="0.5dp"
                android:color="#60D4AF37" /> <!-- 60% Alpha Gold thread -->
        </shape>
    </item>
</layer-list>
